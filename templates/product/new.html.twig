{% extends 'base.html.twig' %}

{% block title %}New Product{% endblock %}

{% block body %}
<h1>Create New Product</h1>

{{ form_start(form, {"attr": {"novalidate": "novalidate"}}) }}

    {{ form_row(form.name) }}

    {{ form_row(form.description) }}

    {{ form_row(form.size) }}

    {{ form_row(form.save, {"label": "Save"}) }}

{{ form_end(form) }}

{% endblock %}
